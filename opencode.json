{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "amazon-bedrock": {
      "options": {
        "profile": "claude-code",
        "region": "us-east-1"
      }
    }
  },
  "mcp": {
    "aws-mcp": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-proxy-for-aws@latest",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--metadata",
        "AWS_REGION=us-east-1"
      ],
      "enabled": true,
      "environment": {
        "READ_OPERATIONS_ONLY": "true"
      }
    },
    "brave-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "enabled": true,
      "environment": {
        "BRAVE_API_KEY": "XXXXXX"
      }
    },
    "aws-knowledge": {
      "type": "local",
      "command": [
        "uvx",
        "fastmcp",
        "run",
        "https://knowledge-mcp.global.api.aws"
      ],
      "enabled": true
    },
    "awslabs.documentation": {
      "type": "local",
      "command": [
        "uvx",
        "awslabs.aws-documentation-mcp-server@latest"
      ],
      "enabled": true,
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_DOCUMENTATION_PARTITION": "aws"
      }
    },
    "awslabs.billing": {
      "type": "local",
      "command": [
        "uvx",
        "awslabs.billing-cost-management-mcp-server@latest"
      ],
      "enabled": true,
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_PROFILE": "claude-code",
        "AWS_REGION": "us-east-1"
      }
    },
    "awslabs.pricing": {
      "type": "local",
      "command": [
        "uvx",
        "awslabs.aws-pricing-mcp-server@latest"
      ],
      "enabled": true,
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_PROFILE": "claude-code",
        "AWS_REGION": "us-east-1"
      }
    }
  },
  "tools": {
    "brave-search": true
  }
}
