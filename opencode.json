{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "aws-mcp": {
      "type": "local",
      "command": ["uvx", "mcp-proxy-for-aws@latest", "https://aws-mcp.us-east-1.api.aws/mcp", "--metadata", "AWS_REGION=us-west-2"],
      "enabled": true,
      "environment":{"READ_OPERATIONS_ONLY": "true"}
    }
  }
}
